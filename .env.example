# Copy to .env.local and fill in your keys

# Primary Chat Brain: Claude via tokenlb.net
CLAUDE_API_KEY=
CLAUDE_BASE_URL=https://tokenlb.net/v1
CLAUDE_MODEL=claude-sonnet-4-6

# Backup & Voice: Groq (https://console.groq.com/keys)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Upstash Redis — required for production sessions on Vercel (https://upstash.com)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional: enable only for private judging/testing, never for public production.
NEXT_PUBLIC_ENABLE_DEMO_TRACKING=false
NEXT_PUBLIC_DEMO_TRACKING_REF=VPAY827982BA

# At least one of CLAUDE_API_KEY or GROQ_API_KEY is required for chat.
